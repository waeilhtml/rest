	if req.Password != "" {
		hashedPassword, _ := bcrypt.GenerateFromPassword([]byte(req.Password), bcrypt.DefaultCost)
		database.DB.Exec("UPDATE users SET password = ? WHERE id = ?", string(hashedPassword), id)
	}

	permissions := strings.Join(req.Permissions, ",")
	_, err = database.DB.Exec("UPDATE users SET name = ?, phone = ?, permissions = ? WHERE id = ?",
		req.Name, req.Phone, permissions, id)
	if err != nil {
		sendError(w, http.StatusInternalServerError, "Erreur lors de la mise a jour")
		return
	}

	userID := r.Context().Value("user_id").(int)
	database.AddAuditLog(userID, "update_staff", fmt.Sprintf("Modification employe ID: %d", id), r.RemoteAddr)

	sendSuccess(w, nil, "Employe mis a jour avec succes")
}

