func ValidateCoupon(w http.ResponseWriter, r *http.Request) {
	var req struct {
		Code string `json:"code"`
	}
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		sendError(w, http.StatusBadRequest, "Donnees invalides")
		return
	}

	req.Code = strings.ToUpper(req.Code)

	coupon, err := database.GetCouponByCode(req.Code)
	if err != nil {
		sendError(w, http.StatusNotFound, "Coupon invalide")
		return
	}

	if coupon.Expires != "" {
		expires, _ := time.Parse("2006-01-02", coupon.Expires)
		if expires.Before(time.Now()) {
			sendError(w, http.StatusBadRequest, "Coupon expire")
			return
		}
	}

	if coupon.Uses >= coupon.MaxUses {
		sendError(w, http.StatusBadRequest, "Coupon deja utilise le nombre maximum de fois")
		return
	}

	sendSuccess(w, coupon, "Coupon valide")
}

