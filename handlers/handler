// ==================== Upload Handlers ====================

func UploadFile(w http.ResponseWriter, r *http.Request) {
	file, handler, err := r.FormFile("file")
	if err != nil {
		sendError(w, http.StatusBadRequest, "Erreur lors de l'upload")
		return
	}
	defer file.Close()

	allowedTypes := []string{"image/jpeg", "image/png", "image/webp", "image/jpg"}
	fileType := handler.Header.Get("Content-Type")
	allowed := false
	for _, t := range allowedTypes {
		if fileType == t {
			allowed = true
			break
		}
	}
	if !allowed {
		sendError(w, http.StatusBadRequest, "Type de fichier non autorise")
		return
	}

	filename := fmt.Sprintf("%d_%s", time.Now().UnixNano(), handler.Filename)

	sendSuccess(w, map[string]interface{}{
		"filename": filename,
		"url":      "/uploads/" + filename,
	}, "Fichier uploade avec succes")
}

