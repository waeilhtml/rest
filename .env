# وضع التشغيل: production / development
APP_ENV=production

# MariaDB (إنتاج)
DB_HOST=localhost
DB_PORT=3306
DB_USER=ssc_prod_user
DB_PASSWORD=123456
DB_NAME=ssc_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=RedisSecure2024!

# JWT
JWT_SECRET=super-secret-key-2024-production-change-this-now
JWT_EXPIRY=24h

# Rate Limiting
RATE_LIMIT=100
RATE_LIMIT_WINDOW=60

# TLS/SSL
TLS_CERT=/etc/ssl/certs/ssc.crt
TLS_KEY=/etc/ssl/private/ssc.key

# Site (تونس)
SITE_NAME=Smart Step Control Tunisie
SITE_PHONE=+216 70 000 000
SITE_EMAIL=contact@ssc.tn
SITE_ADDRESS=Centre Urbain Nord, Tunis, Tunisie

# Uploads
MAX_UPLOAD_SIZE=2097152  # 2MB
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp

# Backup
BACKUP_PATH=/var/backups/ssc
